<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100">
  <div class="flex min-h-screen">
    <%- include('../layouts/sidebar') %>
    <div class="flex-1 flex flex-col">
      <%- include('../layouts/header') %>
      <main class="p-6 flex-1">

        <!-- Form Tambah Role -->
        <div class="bg-white rounded-lg shadow p-6 mb-6">
          <h2 class="text-lg font-semibold mb-4 text-gray-700">Tambah Role</h2>
          <form action="/roles" method="POST" class="flex gap-3">
            <input type="text" name="name" placeholder="Nama role" required
              class="border rounded px-3 py-2 flex-1">
            <button type="submit"
              class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">
              Tambah
            </button>
          </form>
        </div>

        <!-- Tabel Role -->
        <div class="bg-white rounded-lg shadow p-6 mb-6">
          <h2 class="text-lg font-semibold mb-4 text-gray-700">Daftar Role</h2>
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-gray-100 text-left">
                <th class="px-4 py-2">ID</th>
                <th class="px-4 py-2">Nama Role</th>
                <th class="px-4 py-2">Aksi</th>
              </tr>
            </thead>
            <tbody>
              <% roles.forEach(role => { %>
              <tr class="border-t hover:bg-gray-50">
                <td class="px-4 py-2"><%= role.id %></td>
                <td class="px-4 py-2"><%= role.name %></td>
                <td class="px-4 py-2">
                  <form action="/roles/<%= role.id %>/delete" method="POST">
                    <button class="bg-red-500 text-white px-3 py-1 rounded hover:bg-red-600 text-xs">
                      Hapus
                    </button>
                  </form>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <!-- Form Assign Permission -->
        <div class="bg-white rounded-lg shadow p-6">
          <h2 class="text-lg font-semibold mb-4 text-gray-700">Assign Permission ke Role</h2>
          <form action="/roles/assign-permission" method="POST" class="flex gap-3 flex-wrap">
            <select name="role_id" required class="border rounded px-3 py-2">
              <option value="">-- Pilih Role --</option>
              <% roles.forEach(role => { %>
                <option value="<%= role.id %>"><%= role.name %></option>
              <% }) %>
            </select>
            <select name="permission_id" required class="border rounded px-3 py-2">
              <option value="">-- Pilih Permission --</option>
              <% permissions.forEach(p => { %>
                <option value="<%= p.id %>"><%= p.name %></option>
              <% }) %>
            </select>
            <button type="submit"
              class="bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700">
              Assign
            </button>
          </form>
        </div>

      </main>
      <%- include('../layouts/footer') %>
    </div>
  </div>
</body>
</html>