<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100">
  <div class="flex min-h-screen">
    <%- include('../layouts/sidebar') %>
    <div class="flex-1 flex flex-col">
      <%- include('../layouts/header') %>
      <main class="p-6 flex-1">

        <!-- Form Tambah User -->
        <div class="bg-white rounded-lg shadow p-6 mb-6">
          <h2 class="text-lg font-semibold mb-4 text-gray-700">Tambah User</h2>
          <form action="/users" method="POST" class="flex gap-3 flex-wrap">
            <input type="text" name="username" placeholder="Username" required
              class="border rounded px-3 py-2 flex-1 min-w-[150px]">
            <input type="password" name="password" placeholder="Password" required
              class="border rounded px-3 py-2 flex-1 min-w-[150px]">
            <select name="role_id" required class="border rounded px-3 py-2">
              <option value="">-- Pilih Role --</option>
              <% roles.forEach(role => { %>
                <option value="<%= role.id %>"><%= role.name %></option>
              <% }) %>
            </select>
            <button type="submit"
              class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">
              Tambah
            </button>
          </form>
        </div>

        <!-- Tabel User -->
        <div class="bg-white rounded-lg shadow p-6">
          <h2 class="text-lg font-semibold mb-4 text-gray-700">Daftar User</h2>
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-gray-100 text-left">
                <th class="px-4 py-2">ID</th>
                <th class="px-4 py-2">Username</th>
                <th class="px-4 py-2">Role</th>
                <th class="px-4 py-2">Aksi</th>
              </tr>
            </thead>
            <tbody>
              <% users.forEach(u => { %>
              <tr class="border-t hover:bg-gray-50">
                <td class="px-4 py-2"><%= u.id %></td>
                <td class="px-4 py-2"><%= u.username %></td>
                <td class="px-4 py-2">
                  <span class="bg-blue-100 text-blue-700 px-2 py-1 rounded text-xs">
                    <%= u.role_name || '-' %>
                  </span>
                </td>
                <td class="px-4 py-2 flex gap-2">
                  <form action="/users/<%= u.id %>/delete" method="POST">
                    <button class="bg-red-500 text-white px-3 py-1 rounded hover:bg-red-600 text-xs">
                      Hapus
                    </button>
                  </form>
                </td>
              </tr>
              <% }) %>
              <% if (users.length === 0) { %>
              <tr>
                <td colspan="4" class="px-4 py-4 text-center text-gray-400">Belum ada user</td>
              </tr>
              <% } %>
            </tbody>
          </table>
        </div>

      </main>
      <%- include('../layouts/footer') %>
    </div>
  </div>
</body>
</html>